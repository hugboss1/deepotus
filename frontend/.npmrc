# Fallback config in case Vercel still uses npm despite vercel.json.
# CRA 5 has peer-dep mismatches; legacy-peer-deps avoids ERESOLVE failures.
legacy-peer-deps=true
# Avoid silent engine warnings; Node 20 is enforced via .nvmrc.
engine-strict=false
# Long network timeouts for slow CI environments.
fetch-timeout=300000
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
# Prefer offline cache when available.
prefer-offline=true
